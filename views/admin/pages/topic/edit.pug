extends ../../layouts/default.pug

block main
  h1.mb-4 #{pageTitle}
  .card
    .card-body
      form(action=`${prefixAdmin}/topics/edit/${topic._id}` method="POST")
        .form-group
          label(for="title") Ten chu de
          input.form-control(type="text" id="title" name="title" required value=topic.title)

        .form-group
          label(for="avatar") Link anh
          input.form-control(type="text" id="avatar" name="avatar" value=topic.avatar)

        .form-group
          label(for="description") Mo ta
          textarea.form-control.editor(id="description" name="description" rows="5") #{topic.description}

        .form-group
          label Trang thai
          .form-check
            input.form-check-input(type="radio" id="status-active" name="status" value="active" checked=topic.status === "active")
            label.form-check-label(for="status-active") Hoat dong
          .form-check
            input.form-check-input(type="radio" id="status-inactive" name="status" value="inactive" checked=topic.status === "inactive")
            label.form-check-label(for="status-inactive") Dung hoat dong

        .mt-3
          button.btn.btn-primary(type="submit") Cap nhat
          a.btn.btn-secondary.ml-2(href=`${prefixAdmin}/topics`) Quay lai
