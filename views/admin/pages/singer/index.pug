extends ../../layouts/default.pug

block main
  h1.mb-4 #{pageTitle}

  .card.mb-3
    .card-header Danh sach
    .card-body.text-right
      a.btn.btn-outline-success(href=`${prefixAdmin}/singers/create`) + Them moi

  .card
    .card-body
      if singers && singers.length > 0
        .table-responsive
          table.table.table-hover
            thead
              tr
                th STT
                th Anh
                th Ca si
                th Trang thai
                th Slug
                th Hanh dong
            tbody
              each item, index in singers
                tr
                  td #{index + 1}
                  td
                    if item.avatar
                      img(src=item.avatar, alt=item.fullName, style="width:72px;height:72px;object-fit:cover;border-radius:12px;")
                    else
                      span.text-muted Chua co anh
                  td #{item.fullName}
                  td
                    span(class=`badge ${item.status === "active" ? "badge-success" : "badge-secondary"}`) #{item.status}
                  td #{item.slug}
                  td
                    a.btn.btn-sm.btn-warning.mr-2(href=`${prefixAdmin}/singers/edit/${item._id}`) Sua
                    form(action=`${prefixAdmin}/singers/delete/${item._id}` method="POST" style="display:inline-block;")
                      button.btn.btn-sm.btn-danger(type="submit" onclick="return confirm('Ban co chac muon xoa ca si nay?')") Xoa
      else
        p.mb-0.text-muted Chua co ca si nao.
